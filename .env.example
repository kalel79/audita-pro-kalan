# ============================================================
#  AUDITA PRO KALAN - Variables de entorno
# ============================================================
# Copia este archivo a ".env" y rellena con tus credenciales reales.
# NUNCA subas el archivo .env a GitHub (ya está en .gitignore).

# URL de tu proyecto Supabase
# La encuentras en: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Clave pública (anon/public) de Supabase
# La encuentras en: Supabase Dashboard > Settings > API > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key_here

# Nombre del bucket de almacenamiento para fotos de hallazgos
VITE_SUPABASE_BUCKET=hallazgos
